# ========================================
# プライベート設定テンプレート（git 非追跡）
# ========================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# .env には .env.public にない機密情報や個人固有の設定を記載します
# .env.public で定義済みの値を上書きする場合もここに記載します

# NovelAI API トークン（メール+パスワードログインの代わりに使用可）
# NOVELAI_API_TOKEN=pst-...

# テスト用 NovelAI アカウント認証情報（実アカウントの Anlas 残高確認などに使用）
# NOVELAI_TEST_EMAIL=your_email@example.com
# NOVELAI_TEST_PASSWORD=your_password
