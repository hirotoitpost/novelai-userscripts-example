# ========================================
# プライベート設定テンプレート（git 非追跡）
# ========================================
# このファイルをコピーして .env を作成してください:
#   cp .env.example .env
#
# .env には .env.public にない機密情報や個人固有の設定を記載します
# .env.public で定義済みの値を上書きする場合もここに記載します

# NovelAI API トークン（メール+パスワードログインの代わりに使用可）
# NOVELAI_API_TOKEN=pst-...

# テスト用 NovelAI アカウント認証情報（実アカウントの Anlas 残高確認などに使用）
# NOVELAI_TEST_EMAIL=your_email@example.com
# NOVELAI_TEST_PASSWORD=your_password

# ========================================
# vLLM サーバー設定（AI アシスタント機能）
# ========================================
# GPU 1枚構成: 両方を同じ URL に向ける（Qwen2-VL はテキスト+ビジョン両対応）
# GPU 2枚構成: それぞれ別ポートの vLLM インスタンスに向ける

# テキスト生成モデル（プロンプト整形・キャラ設定・物語ドラフト等）
# VLLM_BASE_URL=http://localhost:8001/v1
# VLLM_MODEL=Qwen/Qwen2-VL-7B-Instruct

# ビジョンモデル（リバースプロンプト）
# GPU 1枚の場合はテキストと同じ URL を設定
# VLLM_VISION_BASE_URL=http://localhost:8001/v1
# VLLM_VISION_MODEL=Qwen/Qwen2-VL-7B-Instruct

# Hugging Face トークン（Docker Compose でのモデルダウンロードに使用）
# HF_TOKEN=hf_...
